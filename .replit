modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Development Server"

[[workflows.workflow]]
name = "Development Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OPENAI_BASE_URL=https://api.groq.com/openai/v1 MODEL_NAME=llama-3.1-8b-instant uvicorn server:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "cloudrun"
run = ["bash", "-c", "OPENAI_BASE_URL=https://api.groq.com/openai/v1 MODEL_NAME=llama-3.1-8b-instant uvicorn server:app --host 0.0.0.0 --port 5000"]
