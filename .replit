modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LLM Server"

[[workflows.workflow]]
name = "LLM Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OPENAI_API_KEY=sk-dummy-key-for-testing-12345 uvicorn server:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
